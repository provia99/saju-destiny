# 환경변수 설정 예시
SECRET_KEY=banya-secret-key-change-this-2026
DB_PATH=data/banya.db
SAJU_ENGINE_PATH=engine

# ── 호스트 분리 (서브도메인별 접근 가드) ────────────────
# 프로덕션에서 활성화 권장. 로컬 개발(localhost)은 자동 우회됨.
#
# ENABLE_HOST_GUARD=true 로 설정 시:
#   admin.<domain>  → /admin/* 만 접근 가능
#   master.<domain> → /members, /clients, /saju/(edit|write|api) 만 접근 가능
#   <domain> 또는 브랜드.<domain> → 그 외 (공개 B2C, 결제 등)
#
ENABLE_HOST_GUARD=false
ADMIN_HOST=admin.saju8ja.co.kr
MASTER_HOST=master.saju8ja.co.kr

# ── SMTP (Gmail) ────────────────────────────────────────
# Gmail 앱 비밀번호: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── 토스 결제 ───────────────────────────────────────────
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
